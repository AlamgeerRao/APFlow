<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\APFlow.Application\APFlow.Application.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Bug fix (found during WP-002 offline verification) - see APFlow.Application.csproj. -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="9.0.18" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Needed for GraphMailboxHealthCheck (IHealthCheck/HealthCheckResult). Same
      technique as APFlow.Infrastructure's FrameworkReference for IHttpContextAccessor
      (WP-002) - not a NuGet package, no new external dependency.
    -->
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Graph" Version="5.68.0" />
    <!--
      Azure.Identity here is a separate reference from APFlow.Infrastructure's copy
      (version 1.13.1, used for Key Vault) - Infrastructure and Integrations must never
      reference each other (Solution Structure §2), so each takes its own dependency.
      Kept at the same version deliberately for consistency; update both together.
    -->
    <PackageReference Include="Azure.Identity" Version="1.13.1" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Version chosen from training knowledge (the GA-stable Azure.AI.DocumentIntelligence
      SDK, the renamed successor to Azure.AI.FormRecognizer) - NOT verified against a
      real NuGet feed. The API usage in DocumentIntelligenceOperations.cs WAS checked
      against real Microsoft documentation/samples after WP-008 review (web search) -
      see that file's doc comment for what was confirmed and what remains residual risk.
    -->
    <PackageReference Include="Azure.AI.DocumentIntelligence" Version="1.0.0" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>APFlow.Integrations</RootNamespace>
    <AssemblyName>APFlow.Integrations</AssemblyName>
  </PropertyGroup>

</Project>
